<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F8FC">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:title="Ajustes"
        app:titleTextColor="#061A40"
        app:navigationIcon="?attr/homeAsUpIndicator"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="24dp">
        <TextView android:id="@+id/tvUsuario" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="18sp"
            android:textColor="#061A40" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvRol" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="15sp"
            android:textColor="#5F5E5A" android:layout_marginBottom="32dp"/>
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
        <Button android:id="@+id/btnCerrarSesion" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Cerrar sesion"
            android:backgroundTint="#D32F2F" android:textColor="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>